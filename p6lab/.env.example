# Template for p6lab/.env — copy this to .env and fill in real values.
# The real .env is gitignored; this template is committed.
#
# Usage:
#     cp .env.example .env
#     # edit .env with real webhook URLs
#     set -a && source .env && set +a

# Discord incoming webhook URL (required for WebhookRenderer "discord")
# Create via: Server Settings → Integrations → Webhooks → New Webhook
P6LAB_DISCORD_WEBHOOK_URL=

# Slack incoming webhook URL (optional)
# Create via: https://api.slack.com/apps → Incoming Webhooks
P6LAB_SLACK_WEBHOOK_URL=

# Tuning (all optional — pyproject defaults are sensible)
# P6LAB_WEBHOOK_MIN_SCORE=0.80
# P6LAB_WEBHOOK_MAX_PER_MINUTE=20
